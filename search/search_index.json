{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230Jack_Steve\u7684\u4e2a\u4eba\u7f51\u7ad9","text":"<p>\u8fd9\u91cc\u4f1a\u6709\u672c\u4eba\u7684\u7b14\u8bb0\u4ee5\u53ca\u5176\u5b83\u597d\u73a9\u7684\u4e1c\u897f</p> <p>\u5982\u679c\u60f3\u8981\u56de\u5230\u8fd9\u4e2a\u9875\u9762\uff0c\u6309\u7f51\u7ad9\u5de6\u4e0a\u89d2\u7684\u56fe\u6807\u5373\u53ef</p>"},{"location":"notes/Markdown%E6%B5%8B%E8%AF%95/","title":"Markdown\u6d4b\u8bd5","text":"<ul> <li>test1<ul> <li>test2</li> <li>test3<ul> <li>test4</li> </ul> </li> </ul> </li> </ul>"},{"location":"notes/Untitled-1/","title":"Untitled 1","text":"<p>Q\uff1a\u4f60\u4eec\u80fd\u4e0d\u80fd\u4ecb\u7ecd\u4e00\u4e0b\u4f60\u81ea\u5df1\u548c\u7231\u4e50\u4e50\u56e2\uff1f</p> <p>\u7231\u4e50\u4e50\u56e2\u5c31\u662f\u4f60\u6f14\u51fa\u53ea\u80fd\u4e3a\u4e3b\u7684\u4e00\u4e2a\u97f3\u4e50\u793e\u56e2\u7136\u540e\u5e73\u5e38\u7684\u65f6\u5019\u5c31\u662f\u6392\u7ec3\u8282\u76ee\u7136\u540e\u5230\u65f6\u5019\u7ed9\u5927\u5bb6\u5e26\u6765\u6bd4\u8f83\u9ad8\u8d28\u91cf\u7684\u6f14\u51fa\u3002\u6211\u7684\u8bdd\u6211\u662f\u5c0f\u65f6\u5019\u63a5\u53d7\u8fc7\u6bd4\u8f83\u7cfb\u7edf\u7684\u58f0\u4e50\u6559\u5b66\uff0c\u5c31\u662f\u8fd9\u6837\u3002</p> <p>Q\uff1a\u4f60\u4eec\u662f\u7231\u4e50\u4e50\u56e2\u5bf9\u97f3\u4e50\u7684\u5174\u8da3\u548c\u70ed\u7231\u4f60\u4eec\u51dd\u805a\u5728\u4e00\u8d77\u4f60\u8ba4\u4e3a\u97f3\u4e50\u80fd\u4e3a\u9ad8\u4e2d\u751f\u5e26\u6765\u54ea\u4e9b\u4ef7\u503c\uff1f</p> <p>\u60c5\u7eea\u4ef7\u503c\uff0c\u5c31\u662f\u8fd9\u6709\u70b9\u865a\u65e0\u7f25\u7f08\uff0c\u4f46\u662f\u97f3\u4e50\u5bf9\u4e8e\u5168\u4eba\u7c7b\u6765\u8bf4\u4ece\u53e4\u81f3\u4eca\u90fd\u662f\u4e00\u4e2a\u975e\u5e38\u5b9d\u8d35\u7684\u8d22\u5bcc\u3002\u7136\u540e\u6211\u8ba4\u4e3a\u5462\u5bf9\u4e8e\u9ad8\u4e2d\u751f\u6765\u8bf4\u4e5f\u662f\u80af\u5b9a\u4e5f\u662f\u4e00\u6837\uff0c\u56e0\u4e3a\u9ad8\u4e2d\u5b66\u4e60\u538b\u529b\u6bd4\u8f83\u5927\u561b\u5f88\u591a\u540c\u5b66\u90fd\u4f1a\u9760\u97f3\u4e50\u6765\u7f13\u89e3\uff0c\u8fd9\u662f\u89c2\u4f17\u5c42\u9762\u3002\u4ece\u6211\u4eec\u6f14\u51fa\u4eba\u5458\u5c42\u9762\u7684\u8bdd\u5462\u5927\u5bb6\u90fd\u975e\u5e38\u4eab\u53d7\u5728\u821e\u53f0\u4e0a\u7684\u90a3\u79cd\u8fc7\u7a0b\uff0c\u90a3\u79cd\u611f\u89c9\u3002</p> <p>Q\uff1a\u521a\u4e3e\u529e\u7684\u97f3\u4e50\u4f1a\u83b7\u5f97\u4e86\u4e00\u81f4\u597d\u8bc4\uff0c\u53f0\u4e0a\u7684\u7cbe\u5f69\u79bb\u4e0d\u5f00\u4f60\u4eec\u53f0\u4e0b\u7684\u7528\u529f\u3002\u4f5c\u4e3a\u8868\u6f14\u8005\uff0c\u97f3\u4e50\u4f1a\u7684\u6392\u7ec3\u662f\u5426\u5bf9\u4f60\u7684\u5b66\u4e60\u751f\u6d3b\u4ea7\u751f\u4e86\u5f71\u54cd\uff1f\u4ece\u97f3\u4e50\u4f1a\u4e2d\u53c8\u6536\u83b7\u4e86\u4ec0\u4e48\uff1f</p> <p>\u5f71\u54cd\u80af\u5b9a\u662f\u6709\u7684\u3002\u56e0\u4e3a\u5355\u770b\u8fd9\u4e2a\u97f3\u4e50\u4f1a\u5b83\u8981\u51c6\u5907\u7684\u5176\u5b9e\u5c31\u51e0\u4e2a\u65b9\u9762\uff0c\u6bd4\u5982\u8bf4\u5916\u8054\u793e\u56e2\u554a\u90a3\u4e2a\u8ddf\u5e7f\u64ad\u7ad9\u548c\u8857\u821e\u793e\u8054\u7cfb\u8fd8\u6709\u5c31\u662f\u6b63\u5e38\u6f14\u51fa\u7684\u6392\u7ec3\u554a\uff0c\u8fd8\u6709\u5c31\u662f\u6f14\u51fa\u821e\u53f0\u7684\u8bbe\u8ba1\u8fd9\u4e9b\u3002\u4f46\u662f\u5c31\u662f\u6bcf\u4e00\u70b9\u4ed6\u771f\u6b63\u5b9e\u65bd\u7684\u65f6\u5019\u662f\u5f88\u56f0\u96be\u7684\uff0c\u662f\u8981\u8003\u8651\u5f88\u591a\u3002\u4f46\u662f\u6211\u4f9d\u7136\u89c9\u5f97\u8fd9\u662f\u5f88\u5b9d\u8d35\u7684\u4e00\u4e2a\u7ecf\u5386\uff0c\u56e0\u4e3a\u8fd9\u79cd\u6d3b\u52a8\u6574\u4e2a\u9ad8\u4e2d\u751f\u6d3b\u4e0b\u6765\u4e5f\u4e0d\u4f1a\u6709\u51e0\u6b21\u6240\u4ee5\u8fd9\u662f\u6211\u4eba\u751f\u5f88\u5b9d\u8d35\u7684\u4e00\u4e2a\u7ecf\u9a8c\uff0c\u5bf9\u4e8e\u6211\u4eec\u90fd\u662f\u3002</p> <p>Q\uff1a\u5b66\u597d\u97f3\u4e50\u5b66\u597d\u4e00\u95e8\u4e50\u5668\u662f\u4e00\u4e2a\u5f88\u8270\u96be\u8fc7\u7a0b\uff0c\u4f60\u662f\u5426\u4e5f\u7ecf\u5386\u4e86\u4ece\u91cf\u53d8\u5230\u8d28\u53d8\u4ece\u4e0d\u60c5\u613f\u5230\u70ed\u7231\u7684\u8fc7\u7a0b\u5462\uff1f\u5728\u8fd9\u4e2a\u5b66\u4e60\u7684\u8fc7\u7a0b\u4e2d\u4f60\u6536\u83b7\u4e86\u4ec0\u4e48\uff1f</p> <p>\u8fd9\u4e2a\u80af\u5b9a\u662f\u6709\u7684\u3002\u5c31\u662f\u867d\u7136\u6211\u662f\u4ece\u5c0f\u5f00\u59cb\u6709\u58f0\u4e50\u8bfe\uff0c\u4f46\u662f\u5c31\u662f\u5bf9\u8fd9\u4ef6\u4e8b\u60c5\u6bd4\u8f83\u4e0a\u5fc3\u6bd4\u8f83\u611f\u5174\u8da3\u7684\u65f6\u5019\u662f\u4e00\u4e2a\u5f88\u5c34\u5c2c\u7684\u65f6\u5019\uff0c\u5c31\u662f\u6211\u5728\u53d8\u58f0\u671f\u9010\u6e10\u5bf9\u5531\u6b4c\u8fd9\u4e2a\u4e8b\u60c5\u611f\u5174\u8da3\u7684\uff0c\u6240\u4ee5\u5f53\u65f6\u5c31\u74f6\u9888\u7279\u522b\u591a\u561b\uff0c\u5c31\u662f\u5404\u79cd\u53d1\u58f0\u65b9\u5f0f\u554a\u4ec0\u4e48\u7684\u5c31\u8fd9\u4e9b\u6280\u672f\u90fd\u5904\u7406\u4e0d\u597d\uff0c\u6574\u4e2a\u8eab\u4f53\u611f\u89c9\u4ed6\u7279\u522b\u6df7\u4e71\uff0c\u5c31\u662f\u5b8c\u5168\u63a7\u5236\u4e0d\u4e86\u808c\u8089\u7684\u53d1\u529b\u554a\u5589\u90e8\u7684\u4e00\u4e9b\u808c\u8089\u5b8c\u5168\u63a7\u5236\u4e0d\u4e86\uff0c\u7136\u540e\u5c31\u6162\u6162\u78e8\u6162\u6162\u78e8\u55ef\uff0c\u8fd9\u5c31\u662f\u91cf\u53d8\u5230\u8d28\u53d8\u7684\u4e00\u4e2a\u8fc7\u7a0b\u3002\u7136\u540e\u5230\u540e\u9762\u5c31\u6162\u6162\u8d8a\u6765\u8d8a\u597d\u7136\u540e\u58f0\u97f3\u7684\u4f4d\u7f6e\u4e5f\u53ef\u4ee5\u627e\u5230\u4e86\uff0c\u6240\u4ee5\u5bf9\u6211\u5b66\u4e60\u4e00\u4e2a\u542f\u53d1\u5c31\u662f\u523b\u610f\u7ec3\u4e60\uff0c\u4ed6\u662f\u5f88\u91cd\u8981\u7684\u3002\u7136\u540e\u8fd8\u6709\u4e00\u4e2a\u590d\u5229\u66f2\u7ebf\u7684\u95ee\u9898\u5c31\u662f\u7ec3\u4e60\u4e00\u4e2a\u6280\u80fd\u7684\u8bdd\u521a\u5f00\u59cb\u90fd\u4f1a\u5f88\u56f0\u96be\u7136\u540e\u5230\u540e\u6765\u4f1a\u6709\u4e00\u4e2a\u7a81\u98de\u731b\u8fdb\u3002</p> <p>Q\uff1a\u7231\u4e50\u56e2\u8fd9\u6b21\u7684\u97f3\u4e50\u4f1a\u7ed9\u6211\u4eec\u5e26\u6765\u4e86\u60ca\u559c\u8d85\u4e4e\u60f3\u8c61\uff0c\u4f60\u4eec\u4eca\u540e\u8fd8\u4f1a\u6709\u54ea\u4e9b\u5b89\u6392\u548c\u6253\u7b97\u5462\uff1f</p> <p>\u5b89\u6392\u5c31\u7ee7\u7eed\u662f\u8fd9\u4e2a\u97f3\u4e50\u76f8\u5173\u7684\u6f14\u51fa\u6d3b\u52a8\u3002\u4f46\u662f\u5c31\u6392\u4e00\u6b21\u97f3\u4e50\u4f1a\u65f6\u95f4\u4e5f\u4e0d\u662f\u5f88\u77ed\uff0c\u53ef\u80fd\u8981\u7684\u5462\u4e0b\u5b66\u671f\uff0c\u6211\u8bf4\u7684\u662f\u53ef\u80fd\u8981\u7b49\u5230\u4e0b\u5b66\u671f\uff0c\u6bd5\u7adf\u516d\u6708\u4e5f\u662f\u4e00\u76f4\u5728\u653e\u5047\uff0c\u4e0d\u592a\u53ef\u80fd\u6709\u65f6\u95f4\u6392\u7ec3\u3002</p>"},{"location":"notes/danq/","title":"The Art Of Danqing","text":"<p>Danqing\u00a0has\u00a0played\u00a0an\u00a0important\u00a0role\u00a0in\u00a0the\u00a0Chinese\u00a0history.\u00a0From\u00a0ancient\u00a0murals\u00a0to\u00a0modern\u00a0Chinese\u00a0paintings\u00a0and\u00a0oil\u00a0paintings,\u00a0the\u00a0art\u00a0of\u00a0Danqing\u00a0has\u00a0accompanied\u00a0the evolution\u00a0of\u00a0Chinese\u00a0history.\u00a0Many\u00a0important\u00a0events\u00a0and\u00a0figures in history\u00a0have\u00a0been recorded\u00a0by\u00a0skillful\u00a0Chinese\u00a0painters\u00a0simply\u00a0using\u00a0red\u00a0and\u00a0indigo,which become precious\u00a0historical\u00a0materials.\u00a0At\u00a0the\u00a0same\u00a0time,\u00a0through\u00a0the\u00a0art\u00a0of Danqing,\u00a0we\u00a0can\u00a0also\u00a0glimpse\u00a0the\u00a0changes\u00a0of\u00a0history\u00a0and\u00a0the\u00a0evolution\u00a0of society.</p> <p>Chinese\u00a0philosophical\u00a0thinking\u00a0has\u00a0had\u00a0an\u00a0important\u00a0influence\u00a0on\u00a0the\u00a0art\u00a0of\u00a0Danqing.LaoZi\u00a0pursues\u00a0the\u00a0beauty\u00a0of nature,\u00a0while\u00a0Confucius\u00a0were\u00a0stressing\u00a0the\u00a0beauty\u00a0of\u00a0harmony.\u00a0These\u00a0ideas\u00a0are\u00a0reflected\u00a0in\u00a0the\u00a0works\u00a0of\u00a0painting.\u00a0Many\u00a0paintings\u00a0convey philosophical\u00a0ideas\u00a0such\u00a0as\u00a0the\u00a0unity\u00a0of\u00a0heaven\u00a0and\u00a0man,\u00a0the\u00a0harmony\u00a0between\u00a0nature\u00a0and\u00a0human,\u00a0and\u00a0the\u00a0empathy\u00a0between\u00a0people\u00a0and\u00a0nature\u00a0through\u00a0the\u00a0depiction\u00a0of natural\u00a0elements\u00a0such\u00a0as\u00a0mountains,\u00a0rivers,\u00a0flowers,\u00a0and\u00a0birds.\u00a0In\u00a0addition,\u00a0Chinese\u00a0calligraphy\u00a0is\u00a0closely\u00a0related\u00a0to\u00a0Danqing\u00a0art.The\u00a0concepts\u00a0of\u00a0ink\u00a0application\u00a0and\u00a0vivid\u00a0style in\u00a0calligraphy\u00a0have\u00a0had\u00a0an\u00a0important\u00a0influence\u00a0on\u00a0the\u00a0development\u00a0of\u00a0Danqing\u00a0art.</p> <p>Religious\u00a0beliefs\u00a0are\u00a0also\u00a0reflected\u00a0in\u00a0the\u00a0art\u00a0of\u00a0Danqing.\u00a0After\u00a0Buddhism\u00a0was introduced\u00a0from\u00a0India\u00a0to\u00a0China,\u00a0Buddhist\u00a0art\u00a0gradually\u00a0integrated\u00a0into\u00a0Chinese\u00a0painting.\u00a0Buddhist\u00a0murals,\u00a0Buddha\u00a0statues\u00a0and\u00a0other\u00a0works,\u00a0with\u00a0their\u00a0unique\u00a0artistic\u00a0style\uff0cenriched\u00a0Chinese\u00a0painting\u00a0art.\u00a0At\u00a0the\u00a0same\u00a0time,\u00a0the\u00a0legends\u00a0of\u00a0Taoism\u00a0and\u00a0the\u00a0images\u00a0of\u00a0immortals\u00a0often\u00a0became\u00a0the\u00a0creative\u00a0themes\u00a0of\u00a0painters,\u00a0making\u00a0the\u00a0art\u00a0of\u00a0Danqing\u00a0more\u00a0diverse\u00a0and\u00a0inclusive.</p> <p>As\u00a0an\u00a0important\u00a0part\u00a0of\u00a0Chinese\u00a0culture,\u00a0Danqing\u00a0is\u00a0closely\u00a0connected\u00a0to\u00a0history,\u00a0philosophy\u00a0and\u00a0religious.It\u00a0is\u00a0not\u00a0only\u00a0an\u00a0art\u00a0form,\u00a0but\u00a0also\u00a0an\u00a0important\u00a0carrier\u00a0of\u00a0the spiritual\u00a0culture\u00a0of\u00a0the\u00a0Chinese\u00a0nation.\u00a0In\u00a0today's\u00a0society,\u00a0with\u00a0the\u00a0advancement\u00a0of science\u00a0and\u00a0technology\u00a0and\u00a0the\u00a0blending\u00a0of\u00a0cultures,\u00a0the\u00a0art\u00a0of\u00a0Danqing\u00a0faces\u00a0new challenges\u00a0and\u00a0opportunities.\u00a0So\u00a0it\u00a0is\u00a0our\u00a0teenager\u2019s\u00a0job\u00a0to\u00a0cherish\u00a0this\u00a0cultural\u00a0heritage,\u00a0carry\u00a0forward\u00a0the\u00a0inner\u00a0beauty\u00a0of\u00a0the\u00a0art\u00a0of\u00a0Danqing,\u00a0and\u00a0let\u00a0it\u00a0shine\u00a0brighter\u00a0in\u00a0the\u00a0new\u00a0century\u00a0of\u00a0China.</p>"},{"location":"notes/test/","title":"Test","text":""},{"location":"notes/test/#this-is-a-test-document","title":"This is a test document","text":""},{"location":"notes/%E4%B9%A1%E5%9C%9F%E4%B8%AD%E5%9B%BD/","title":"\u4e61\u571f\u4e2d\u56fd","text":"<ul> <li> <p>\u7b2c\u4e00\u7ae0\uff1a\u4e2d\u56fd\u57fa\u5c42\u4e61\u571f\u793e\u4f1a\u662f\u719f\u4eba\u793e\u4f1a</p> </li> <li> <p>\u519c\u6c11\u9760\u571f\u5730\u8c0b\u751f</p> </li> <li> <p>\u4eba\u53e3\u7c98\u5728\u571f\u5730\u4e0a\u4e0d\u6d41\u52a8</p> </li> <li> <p>\u73b0\u5b9e\u56e0\u7d20\u51b3\u5b9a\u4eba\u4eec\u805a\u6751\u800c\u5c45</p> <ul> <li> <p>\u5185\u90e8\u719f\u6089</p> </li> <li> <p>\u4eba\u4e0e\u4eba\uff1a\u4ece\u5fc3\u6240\u6b32\u4e0d\u903e\u77e9\uff0c\u5728\u4e00\u8d77\u751f\u957f\u800c\u53d1\u751f\u7684\u793c\u4fd7\u793e\u4f1a\uff08\u60c5\u611f\u5360\u4f18\uff09\u5e76\u975e\u4e3a\u4e86\u4efb\u52a1\u800c\u7ed3\u5408\u7684\u6cd5\u7406\u793e\u4f1a\uff08\u7406\u6027\u5360\u4f18\uff09</p> </li> <li> <p>\u4eba\u4e0e\u73af\u5883\uff1a\u719f\u6089</p> </li> <li> <p>\u6751\u843d\u4e4b\u95f4\u5b64\u7acb\u9694\u9602</p> </li> </ul> </li> <li> <p>\u7b2c\u4e8c\u81f3\u4e09\u7ae0\uff1a\u7a7a\u95f4\u4e0d\u6d41\u52a8\u7684\u4eb2\u5bc6\u6027\u548c\u65f6\u95f4\u91cd\u590d\u7684\u5355\u8c03\u6027\u5e26\u6765\u751f\u6d3b\u5b9a\u578b</p> </li> <li> <p>\u4eba\u9700\u8981\u6587\u5b57\u79ef\u7d2f\u7ecf\u9a8c\u6253\u7834\u65f6\u7a7a\u675f\u7f1a\uff0c\u4e61\u571f\u793e\u4f1a\u751f\u6d3b\u5b9a\u578b\u4e0d\u9700\u8981\u989d\u5916\u7ecf\u9a8c</p> </li> <li>\u6587\u5b57\u4e0d\u5982\u8bed\u8a00\uff0c\u8bed\u8a00\u4e0d\u5982\u7279\u6b8a\u8bed\u8a00\uff08\u58f0\u97f3\uff09</li> <li> <p>\u5982\u679c\u4e61\u571f\u793e\u4f1a\u4e0d\u73b0\u4ee3\u5316\u3001\u57fa\u5c42\u4e0d\u53d8\u5316\uff0c\u6587\u5b57\u6ca1\u6709\u5fc5\u8981\u4e0b\u4e61</p> </li> <li> <p>\u7b2c\u56db\u81f3\u4e03\u7ae0\uff1a\u4e61\u571f\u793e\u4f1a\u4eba\u9645\u5173\u7cfb\u7ed3\u6784\u662f\u5dee\u5e8f\u683c\u5c40</p> </li> <li> <p>\u7ef4\u7cfb\u5b9a\u578b\u751f\u6d3b\u7684\u662f\u5dee\u5e8f\u683c\u5c40\uff08\u4e2d\u897f\u65b9\u5404\u6709\u504f\u80dc\uff09</p> <ul> <li> <p>\u4e2d\u56fd\u4e61\u571f\u793e\u4f1a\u7684\u7ed3\u6784\u662f\u540c\u5fc3\u5706\uff08\u754c\u9650\u4f38\u7f29\uff09\uff1a\u5dee\u5e8f\u683c\u5c40-\u4ee5\u81ea\u5df1\u4e3a\u4e2d\u5fc3-\u4e61\u571f\u98ce\u683c\u81ea\u98df\u5176\u529b\u5f3a\u8c03\u514b\u5df1\u548c\u4fee\u8eab\u3001\u5b5d\u608c\u5fe0\u4fe1\u662f\u79c1\u4eba\u5173\u7cfb</p> </li> <li> <p>\u897f\u65b9\u793e\u4f1a\u662f\u6346\u67f4\uff08\u754c\u9650\u6e05\u6670\uff09\uff1a\u56e2\u4f53\u683c\u5c40-\u4eba\u4eba\u5e73\u7b49\u3001\u6743\u5229\u4e49\u52a1\u5206\u660e-\u6e38\u7267\u98ce\u683c\u76f8\u4e92\u4f9d\u8d56\uff0c\u5f3a\u8c03\u9075\u7eaa\u5b88\u6cd5</p> </li> </ul> </li> <li> <p>\u516c\u79c1\u4e0d\u5206\u6765\u6e90\u4e8e\u6240\u7ad9\u4f4d\u7f6e\u4e0d\u540c</p> </li> <li> <p>\u5dee\u5e8f\u683c\u5c40\u7684\u7ebd\u5e26\u4eba\u4f26\u6765\u81ea\u5112\u5bb6</p> </li> <li> <p>\u5dee\u5e8f\u683c\u5c40\u5bfc\u81f4\u5927\u5bb6\u5ead\uff08\u7ed3\u6784\u4e0a\u800c\u5e76\u975e\u4eba\u53e3\u4e0a\uff09-&gt;\u5c0f\u5bb6\u65cf\uff08\u91cd\u89c6\u7eb5\u5411\u5173\u7cfb\u800c\u5e76\u975e\u6a2a\u5411\u592b\u59bb\u5173\u7cfb\uff09</p> <ul> <li> <p>\u7537\u5973\u6709\u522b\uff08\u751f\u6d3b\u9694\u79bb\u3001\u5fc3\u7406\u758f\u8fdc\uff09\u4fbf\u4e8e\u6291\u5236\u611f\u60c5\u4fc3\u8fdb\u793e\u4f1a\u7a33\u5b9a</p> </li> <li> <p>\u611f\u60c5\u7684\u6fc0\u52a8\u4f1a\u6539\u53d8\u539f\u6709\u7684\u793e\u4f1a\u5173\u7cfb\u3001\u611f\u60c5\u7684\u6de1\u6f20\u80fd\u7a33\u5b9a\u793e\u4f1a\u5173\u7cfb</p> </li> </ul> </li> <li> <p>\u7b2c\u516b\u81f3\u4e5d\u7ae0\uff1a\u4e61\u571f\u793e\u4f1a\u662f\u793c\u6cbb\u793e\u4f1a</p> </li> <li> <p>\"\u4eba\u6cbb\"\u4e5f\u9700\u8981\u89c4\u5219\uff0c\u201c\u6cd5\u6cbb\u201d\u4e5f\u9700\u8981\u4eba</p> </li> <li> <p>\u793c\u6cbb</p> <ul> <li>\u4e2d\u6027\u8bcd\u3001\u4e0d\u662f\u6148\u5584\u548c\u6587\u660e\u800c\u662f\u793e\u4f1a\u516c\u8ba4\u7684\u89c4\u8303</li> <li>\u7ef4\u6301\u7684\u529b\u91cf\u662f\u4f20\u7edf\u793c\u6cbb\u7684\u6839\u672c\u533a\u522b</li> <li>\u4e0d\u662f\u901a\u8fc7\u5916\u754c\u529b\u91cf\u5f3a\u5236\u65bd\u52a0\u800c\u662f\u901a\u8fc7\u6559\u5316\u8ba9\u4eba\u4e3b\u52a8\u670d\u4ece</li> <li>\u4e61\u571f\u793e\u4f1a\u53cd\u5bf9\u8bc9\u8bbc\u3001\u9f13\u52b1\u6559\u5316\uff08\u957f\u8001\u8c03\u89e3\uff09</li> <li>\u4e0d\u77e5\u9053\u793c\u4eea\u79e9\u5e8f\u662f\u803b\u8fb1\u3001\u4e0d\u77e5\u9053\u6cd5\u5f8b\u6ca1\u5173\u7cfb</li> </ul> </li> <li> <p>\u7b2c\u5341\u81f3\u5341\u4e00\u7ae0\uff1a\u60f3\u5410\u793e\u4f1a\u7684\u6743\u529b\u662f\u65e0\u4e3a\u7684\u3001\u6559\u5316\u7684</p> </li> <li> <p>\u793e\u4f1a\u51b2\u7a81-\u6a2a\u66b4\u6743\u529b-\u9636\u7ea7\u538b\u8feb\u83b7\u5f97\u5229\u76ca-\u519c\u6751\u7ecf\u6d4e\u5269\u4f59\u592a\u5c11\u4e0d\u80fd\u7ef4\u6301</p> </li> <li> <p>\u793e\u4f1a\u5408\u4f5c-\u540c\u610f\u6743\u529b-\u793e\u4f1a\u5951\u7ea6\u5206\u5de5\u5408\u4f5c-\u5c0f\u519c\u7ecf\u6d4e\u81ea\u7ed9\u81ea\u8db3\u4e0d\u80fd\u4ea7\u751f</p> </li> <li> <p>\u4e61\u571f\u793e\u4f1a\u7684\u6743\u529b\u7ed3\u6784\u662f\u6559\u5316\u6027\u7684\uff08\u7c7b\u4f3c\u65c5\u5ba2\u987b\u77e5\u3001\u5bb6\u6709\u4e25\u7236\u65cf\u6709\u957f\u8001\uff09</p> <ul> <li> <p>\u6559\u5316\u4e0d\u662f\u5265\u524a\u751a\u81f3\u635f\u5df1\u5229\u4eba</p> </li> <li> <p>\u6559\u5316\u6ca1\u6709\u5f81\u5f97\u88ab\u6559\u5316\u8005\u7684\u540c\u610f</p> </li> <li> <p>\u7a33\u5b9a\u7684\u6587\u5316\u6ecb\u517b\u4e86\u6559\u5316\u65b0\u6210\u5458\u7684\u6743\u529b</p> </li> <li> <p>\u53d8\u8fc1\u7684\u793e\u4f1a\u53d1\u5c55\u4ee3\u66ff\u4e86\u7ecf\u9a8c\u3001\u5f31\u5316\u4e86\u6559\u5316</p> </li> </ul> </li> <li> <p>\u7b2c\u5341\u4e8c\u81f3\u5341\u56db\u7ae0\uff1a\u793e\u4f1a\u6743\u529b\u7684\u53d8\u8fc1</p> </li> <li> <p>\u793e\u4f1a\u53d8\u5316\u901f\u7387\u51b3\u5b9a\u8840\u7f18\u4f5c\u7528\u5f3a\u5f31</p> <ul> <li> <p>\u8840\u7f18\u793e\u4f1a\u7a33\u5b9a\u3001\u8840\u7f18\u5730\u7f18\u5408\u4e00\u3001\u8fc1\u79fb\u4e5f\u4f9d\u65e7\u5e26\u7740\u8840\u7f18</p> </li> <li> <p>\u793e\u4f1a\u7684\u53d1\u5c55\u3001\u5730\u7f18\u7684\u6d41\u52a8\u5e26\u6765\u4e86\u4ece\u4e61\u571f\u5230\u73b0\u4ee3\u7684\u53d8\u8fc1</p> </li> </ul> </li> <li> <p>\u4e61\u571f\u793e\u4f1a\u5e76\u975e\u9759\u6b62\u800c\u662f\u7f13\u6162\u53d8\u5316</p> <ul> <li> <p>\u6162\u7684\u957f\u8001\u6743\u529b</p> </li> <li> <p>\u5feb\u7684\u65f6\u4e8b\u6743\u529b</p> </li> <li> <p>\u793e\u4f1a\u7ed3\u6784\u4e0d\u662f\u81ea\u8eab\u53d8\u52a8</p> </li> <li> <p>\u4e0d\u9002\u5e94\u53d1\u5c55\u5c31\u4f1a\u6709\u6587\u5316\u82f1\u96c4</p> </li> <li> <p>\u957f\u8001\u6743\u529b\u4e0d\u5bb9\u53cd\u5bf9\u548c\u8d28\u7591</p> </li> <li> <p>\u4ea4\u66ff\u8fc7\u7a0b\u4e2d\u5c31\u4f1a\u540d\u5b9e\u5206\u79bb</p> </li> <li> <p>\u957f\u8001\u793e\u4f1a\u9760\u6b32\u671b\u884c\u4e8b</p> </li> <li> <p>\u6b32\u671b\u5408\u4e4e\u4eba\u7c7b\u751f\u5b58\u6761\u4ef6</p> </li> <li> <p>\u6b32\u671b\u7684\u76ee\u7684\u548c\u7ed3\u679c\u5f80\u5f80\u5206\u5316</p> </li> <li> <p>\u6b32\u671b-&gt;\u884c\u4e3a-&gt;\u7ecf\u9a8c-&gt;\u6587\u5316</p> </li> <li> <p>\u73b0\u4ee3\u793e\u4f1a\u9760\u8ba1\u5212\u884c\u4e8b</p> </li> <li> <p>\u6839\u636e\u79d1\u5b66\u5236\u5b9a\u8ba1\u5212\u6ee1\u8db3\u9700\u8981</p> </li> <li> <p>\u77e5\u8bc6\u5373\u6743\u529b</p> </li> </ul> </li> </ul>"},{"location":"notes/%E4%B9%A1%E5%9C%9F%E8%8A%9C%E6%B9%96%E4%B8%AD%E5%9B%BD%E5%B9%B4/","title":"\u4e61\u571f\u829c\u6e56\u4e2d\u56fd\u5e74","text":"<p>\u201c\u90a3\u53e4\u4eba\u81ea\u6709\u53e4\u4eba\u798f\uff0c\u4fac\u83ab\u6bd4\u53e4\u4eba\u6bd4\u81ea\u8eab\u3002\u201d\u94fa\u4e86\u7ea2\u8272\u5730\u6bef\u7684\u91d1\u5c5e\u6846\u67b6\u821e\u53f0\u4e0a\u6b63\u6f14\u7740\u68a8\u7c27\u620f\u7684\u7ecf\u5178\u5267\u76ee\u300a\u73cd\u73e0\u5854\u300b\u3002\u6211\u4ecd\u5982\u5e7c\u65f6\u4e00\u822c\u7ad9\u5728\u90a3\u719f\u6089\u7684\u4f4d\u7f6e\u3002\u5b69\u7ae5\u4eec\u7684\u6b22\u547c\u58f0\uff0c\u8001\u4eba\u4eec\u62c9\u5bb6\u5e38\u7684\u58f0\u97f3\uff0c\u7a00\u7a00\u62c9\u62c9\u7684\u97ad\u70ae\u58f0\u4e0d\u7edd\u4e8e\u8033\u3002\u8fd9\u7684\u786e\u662f\u8bb0\u5fc6\u4e2d\u5b98\u9661\u95e8\u5927\u96c6\u7684\u6837\u8c8c\uff0c\u5374\u53c8\u4e0d\u662f\u8bb0\u5fc6\u4e2d\u591a\u5e74\u524d\u7684\u5b98\u9661\u95e8\u5927\u96c6\u3002</p> <p>\u4ece\u4e00\u4f17\u6b22\u4e50\u7684\u89c2\u4f17\u4e2d\u5356\u529b\u5730\u6324\u8fc7\uff0c\u5348\u540e\u6e29\u6696\u7684\u91d1\u8272\u7684\u9633\u5149\u900f\u8fc7\u53f6\u9699\u503e\u5012\u5728\u5438\u6c34\u7684\u77f3\u7816\u5730\u9762\u4e0a\uff0c\u5448\u73b0\u51fa\u5e74\u753b\u4e0a\u201c\u91d1\u86c7\u5448\u7965\u201d\u7684\u6a21\u6837\u3002\u6211\u7ee7\u7eed\u5411\u524d\u56f0\u60d1\u800c\u5931\u843d\u5730\u8d70\u7740\uff0c\u56db\u5468\u7684\u4e00\u5207\u4f3c\u4e4e\u6084\u6084\u892a\u53bb\u4e86\u989c\u8272\uff0c\u53d8\u6210\u8bb0\u5fc6\u4e2d\u8001\u7167\u7247\u7684\u72ec\u7279\u8272\u6cfd\uff0c\u65e7\u5f0f\u97ad\u70ae\u7684\u58f0\u54cd\u4e5f\u9010\u6e10\u4ece\u56db\u5468\u805a\u62e2\u6765\u3002\u5b8c\u7f8e\u7684\u5e03\u666f\u5440\uff0c\u6211\u8fd9\u4e48\u60f3\u7740\uff0c\u4e0d\u5c0f\u5fc3\u4e00\u811a\u8e0f\u8fdb\u4e86\u56de\u5fc6\u3002</p> <p>\u4e00\u5ea7\u4e0d\u5927\u7684\u5e99\u5b87\u5c06\u5b83\u7684\u5f71\u50cf\u6295\u5165\u6211\u7684\u773c\u5e18\u3002</p> <p>\u8d70\u8fd1\u7ec6\u7ec6\u7aef\u8be6\uff0c\u91d1\u9ec4\u7684\u98de\u6a90\u65e9\u5df2\u892a\u53bb\u4e86\u9c9c\u8273\u7684\u8272\u5f69\uff0c\u6a90\u4e0a\u7684\u810a\u517d\u4e5f\u5df2\u5931\u53bb\u4e86\u5f80\u65e5\u7684\u795e\u91c7\uff0c\u53ea\u6709\u95e8\u4e0a\u60ac\u7740\u7684\u4e00\u5bf9\u753b\u7740\u9752\u8272\u9e1f\u513f\u7684\u5254\u58a8\u7eb1\u706f\u8ba9\u6211\u786e\u5b9a\u8fd9\u4fbf\u662f\u8bb0\u5fc6\u4e2d\u7684\u6768\u6cd7\u5e99\u3002\u7237\u7237\u8bf4\u6768\u6cd7\u5e99\u662f\u4e3a\u4e86\u7eaa\u5ff5\u5b8b\u671d\u6765\u6b64\u5730\u6cbb\u6c34\u7684\u6768\u6cd7\u5c06\u519b\uff0c\u5e74\u5e74\u90fd\u5982\u6b64\u70ed\u95f9\uff0c\u5012\u4e0d\u662f\u4e13\u4e3a\u7eaa\u5ff5\u6768\u6cd7\u5c06\u519b\uff0c\u800c\u662f\u4e3a\u4e86\u8fd9\u5e99\u4f1a(\u73b0\u5df2\u6210\u4e3a\u5b98\u9661\u95e8\u5927\u96c6)\u7684\u70ed\u95f9\uff0c\u4e3a\u4e86\u5b69\u5b50\u4eec\u62ff\u7740\u751f\u8096\u72b6\u7cd6\u753b\u7684\u7b11\u8138\uff0c\u4e5f\u4e3a\u4e86\u90a3\u6211\u4ece\u672a\u89c1\u8fc7\u7684\u201c\u6768\u6cd7\u6253\u6869\u201d\u7684\u8868\u6f14\u3002\u8f6c\u8fc7\u8eab\u6765\uff0c\u9633\u5149\u5df2\u4e0d\u77e5\u4f55\u65f6\u4ece\u4e0b\u5348\u7684\u89d2\u5ea6\u8f6c\u6210\u6b63\u5348\uff0c\u773c\u524d\u7684\u9752\u77f3\u677f\u8def\u6d88\u5931\u4e86\uff0c\u5e7b\u5316\u6210\u4e86\u4e0b\u96e8\u5c31\u4f1a\u7559\u4e0b\u4eba\u4eec\u811a\u5370\u7684\u571f\u8d28\u6cb3\u5824\u3002\u201c\u5c0f\u670b\u53cb\uff0c\u4e00\u8fb9\u800d\u53bb\u3002\u201d\u6709\u4eba\u51b2\u6211\u559d\u4e86\u4e00\u58f0\uff0c\u53c8\u5411\u6211\u624b\u4e2d\u585e\u4e86\u4e00\u5757\u7389\u5e26\u7cd5\u3002\u6211\u88ab\u8fd9\u7a81\u5982\u5176\u6765\u7684\u65ad\u559d\u5413\u4e86\u4e00\u8df3\uff0c\u8d76\u5fd9\u5411\u540e\u9000\u4e86\u51e0\u6b65\uff0c\u8fd8\u4e0d\u5fd8\u54ac\u51e0\u53e3\u7cd5\u3002\u90a3\u4e2a\u4eba\u53c8\u62db\u547c\u5176\u4ed6\u51e0\u4e2a\u8fdb\u5e99\u53bb\u4e86\uff0c\u5927\u81f4\u662f\u4e3a\u4e86\u7948\u798f\uff0c\u6211\u4e00\u5411\u4e0d\u559c\u6b22\u4e25\u8083\u7684\u796d\u7940\u6d3b\u52a8\uff0c\u4f46\u5374\u5bf9\u5176\u540e\u7684\u8868\u6f14\u6781\u611f\u5174\u8da3\u3002\u6b64\u65f6\uff0c\u90a3\u4e9b\u7948\u798f\u7684\u4eba\u4eec\u4ece\u5e99\u91cc\u51fa\u6765\u4e86\uff0c\u5c06\u4e00\u5377\u7ea2\u5f64\u5f64\u7684\u97ad\u70ae\u5c55\u5f00\u6765\uff0c\u63a5\u7740\u4fbf\u662f\u8fde\u7eed\u7684\u6e05\u8106\u7206\u54cd\uff0c\u7ea2\u8272\u788e\u7247\u88ab\u5fae\u98ce\u522e\u8d77\uff0c\u643a\u7740\u65b0\u5e74\u7684\u798f\u6c14\u4e0e\u8fd0\u52bf\u6253\u7740\u65cb\u5411\u6cb3\u5cb8\u98d8\u53bb\uff0c\u5149\u9762\u7684\u3001\u7cd9\u9762\u7684\u7eb8\u7247\u5728\u9633\u5149\u4e0b\u5ffd\u660e\u5ffd\u6697\u5730\u95ea\u7740\u5149\u3002\u6211\u4f3c\u4e4e\u4e5f\u6210\u4e3a\u4e86\u5b83\u4eec\u4e2d\u7684\u4e00\u5458\uff0c\u4efb\u51ed\u6b22\u4e50\u5145\u76c8\u5fc3\u4e2d\u7684\u6bcf\u4e00\u4e2a\u89d2\u843d\uff0c\u5411\u6cb3\u7684\u5bf9\u5cb8\u98de\u53bb\u3002</p> <p>\u5929\u5149\u6e10\u6697\uff0c\u6211\u6240\u671f\u5f85\u7684\u8868\u6f14\u5373\u5c06\u5728\u6b64\u4e0a\u6f14\u3002\u4eba\u7fa4\u5b89\u9759\u4e86\uff0c\u5982\u540c\u5728\u6e05\u6668\u7684\u9ec4\u5c71\u4e0a\u9759\u5f85\u65e5\u51fa\u3002\u8fc7\u4e86\u4e00\u4f1a\u513f\uff0c\u5728\u90a3\u201c\u65e5\u51fa\u201d\u7684\u5730\u65b9\u4e24\u4f4d\u9189\u6c49\u624b\u6301\u7740\u6807\u8bb0\u6c34\u4f4d\u7684\u7ea2\u7ef3\u7a7f\u7740\u559c\u5e86\u800c\u571f\u6c14\u7684\u7ea2\u8272\u9ec4\u8fb9\u7684\u670d\u88c5\u5728\u5bf9\u9762\u7684\u6cb3\u5cb8\u4e0b\u4e86\u6c34\uff0c\u4eba\u4eec\u90fd\u4e0e\u6211\u4e00\u822c\u7565\u5e26\u7d27\u5f20\u5730\u770b\u7740\u4e24\u4f4d\u9189\u6c49\u7b28\u62d9\u5730\u5411\u8fd9\u4e00\u5cb8\u594b\u529b\u5730\u6e38\u6765\uff0c\u5915\u9633\u7684\u6a59\u7ea2\u8272\u7684\u4f59\u6656\u6d12\u5728\u4e8c\u4eba\u7684\u5934\u9876\u4e0a\uff0c\u53c8\u878d\u5728\u4e0d\u65ad\u7ffb\u817e\u7684\u6c34\u6ce2\u91cc\uff0c\u5982\u540c\u6307\u5f15\u7740\u9633\u5149\u7684\u524d\u8fdb\u3002\u4e8c\u4eba\u79bb\u6cb3\u5cb8\u8d8a\u6765\u8d8a\u8fd1\uff0c\u7ffb\u6d8c\u7684\u6c34\u6ce2\u62cd\u6253\u7740\u6c34\u8349\u4e0d\u65ad\u9707\u52a8\u7740\u3002\u7ec8\u4e8e\uff0c\u6709\u4e00\u4eba\u7387\u5148\u767b\u4e0a\u6cb3\u5cb8\uff0c\u6211\u4eec\u7206\u53d1\u51fa\u4e86\u9707\u8033\u6b32\u804b\u7684\u6b22\u547c\uff0c\u4f46\u662f\u8868\u6f14\u8fd8\u8fdc\u8fdc\u6ca1\u6709\u7ed3\u675f\u3002\u6cb3\u5cb8\u8fb9\u63d2\u7740\u56fa\u5b9a\u6728\u6869\u7684\u6768\u6cd7\u5c06\u519b\u5851\u50cf\u5df2\u5728\u6ce5\u4e2d\u606d\u5019\u591a\u65f6\uff0c\u4e8c\u4eba\u8dcc\u8dcc\u649e\u649e\u5730\u62ac\u7740\u5851\u50cf\u5411\u6c34\u9762\u7f13\u7f13\u8d70\u53bb\uff0c\u6211\u4eec\u7684\u5fc3\u4e5f\u968f\u7740\u4ed6\u4eec\u7684\u6bcf\u4e00\u6b21\u8dcc\u5012\u4e0e\u7ad9\u8d77\u8d77\u4f0f\u4e0d\u5b9a\u3002\u65e5\u5149\u9010\u6e10\u6d88\u6563\u4e86\uff0c\u4ec5\u5269\u7684\u51e0\u7f15\u5149\u8292\u900f\u8fc7\u4e91\u5c42\u5728\u6cb3\u5cb8\u8fb9\u52fe\u52d2\u51fa\u4e86\u6597\u6298\u86c7\u884c\u7684\u6cb3\u5cb8\u7684\u8f6e\u5ed3\u3002\u7ec8\u4e8e\uff0c\u4e8c\u4eba\u5c06\u6768\u6cd7\u5c06\u519b\u7684\u5851\u50cf\u7a33\u7a33\u5f53\u5f53\u5730\u63d2\u5728\u4e86\u6c34\u4f4d\u7ebf\u7684\u6ce5\u571f\u91cc\uff0c\u7ed1\u4e0a\u7ea2\u7ef3\uff0c\u65b0\u4e00\u5e74\u7684\u519c\u8015\uff0c\u5c06\u4f1a\u4ee5\u8fd9\u6761\u7ebf\u4e3a\u57fa\u51c6\u3002\u4eba\u4eec\u53c8\u7206\u53d1\u51fa\u4e00\u9635\u6b22\u547c\uff0c\u6211\u4e5f\u968f\u7740\u4ed6\u4eec\u6b22\u547c\u7740\u3002\u65f6\u95f4\u4f3c\u4e4e\u9759\u6b62\u4e86\uff0c\u4e0d\uff0c\u5b83\u5728\u52a0\u901f\u5411\u524d\uff0c\u773c\u524d\u7684\u8001\u65e7\u6ee4\u955c\u6d88\u5931\u4e86\uff0c\u4e00\u5207\u90fd\u6025\u901f\u53d8\u5316\u7740\uff0c\u6cb3\u5824\u53d8\u6210\u4e86\u67cf\u6cb9\u8def\uff0c\u6768\u6cd7\u5e99\u548c\u4e00\u65c1\u7684\u4eba\u4eec\u90fd\u6d88\u5931\u4e86\uff0c\u53d8\u6210\u4e86\u4e00\u4e2a\u4e2a\u73b0\u4ee3\u5316\u7684\u5c0f\u533a\uff0c\u6614\u65e5\u7684\u796d\u7940\u6d3b\u52a8\u53d8\u6210\u4e86\u5546\u4e1a\u5316\u7684\u6f14\u51fa\u4e0e\u9500\u552e\u6d3b\u52a8\u3002\u592a\u9633\u91cd\u65b0\u722c\u4e0a\u5934\u9876\uff0c\u6211\u56de\u5230\u4e86\u73b0\u5b9e\u4e2d\u90a3\u4e2a\u6b63\u5728\u6f14\u7740\u68a8\u7c27\u620f\u7684\u5b98\u9661\u95e8\u5927\u96c6\uff0c\u4e00\u5e55\u5267\u843d\uff0c\u6211\u4eec\u53c8\u4e00\u6b21\u7206\u53d1\u51fa\u4e86\u76f8\u540c\u7684\u6b22\u547c\u58f0\u4e0e\u559d\u5f69\u58f0\uff0c\u4e0e\u591a\u5e74\u524d\u4f55\u5176\u76f8\u4f3c\uff0c\u4f55\u5176\u76f8\u4f3c......\u8fd9\u5c31\u662f\u6211\u8bb0\u5fc6\u4e2d\u7684\u5b98\u9661\u95e8\u5927\u96c6\u3002</p> <p>\u5927\u96c6\u7ed3\u675f\u4e86\uff0c\u6211\u7a7f\u8fc7\u4e00\u4e2a\u4e2a\u5192\u7740\u70ed\u6c14\u7684\u5c0f\u5403\u644a\u5411\u5bb6\u7684\u65b9\u5411\u8d70\u53bb\u3002\u5b69\u5b50\u4eec\u62ff\u7740\u751f\u8096\u72b6\u7684\u7cd6\u753b\u6b22\u7b11\u7740\uff0c\u5c0f\u533a\u91cc\u7684\u7a97\u68c2\u4e0a\u8d34\u7740\u7684\u559c\u5e86\u7684\u201c\u798f\u201d\u5728\u9633\u5149\u4e0b\u95ea\u70c1\u7740\u3002\u6211\u60f3\uff0c\u6216\u8bb8\u5982\u4eca\u7684\u5e74\u4e0e\u8fc7\u53bb\u7684\u5dee\u5f02\u7684\u786e\u660e\u663e\uff0c\u4f46\u662f\u4eea\u5f0f\u53ea\u4e0d\u8fc7\u662f\u8f6c\u77ac\u5373\u901d\u7684\u5f62\u5f0f\uff0c\u4eba\u4eec\u8fc7\u4e2d\u56fd\u5e74\u7684\u5feb\u4e50\u5374\u4e00\u8109\u76f8\u627f\uff0c\u800c\u8fd9\uff0c\u65b9\u662f\u5e74\u3002</p>"},{"location":"notes/%E8%80%83%E7%A0%94%E7%9F%A5%E8%AF%86/","title":"\u8003\u7814","text":"<ul> <li> <p>\u57fa\u672c\u5e38\u8bc6\uff1a</p> </li> <li> <p>\u8003\u7814\u5c4a\u6570\uff1a</p> <p>XX\u8003\u7814\uff0cXX\u4e3a\u7814\u7a76\u751f\u5165\u5b66\u5e74\u4efd\uff0c\u7814\u7a76\u751f\u8003\u8bd5\u5728 20XX-1 \u5e74\u5e95\u4e3e\u884c(\u598226\u8003\u7814\u662f25\u5e74\u5e95\u53c2\u4e0e\u521d\u8bd5\uff0c26\u5e74\u5165\u5b66\u7684\u4e00\u5c4a\u5b66\u751f)</p> </li> <li> <p>\u8003\u7814\u62a5\u540d\u65b9\u5f0f\u4ee5\u53ca\u65f6\u95f4\uff1a\u8003\u524d\u51b3\u5b9a\u5b66\u6821\u53ca\u4e13\u4e1a\uff0c\u4e5d\u6708\u62a5\u540d</p> </li> <li> <p>\u62a5\u8003\u6761\u4ef6\uff1a\u672c\u79d1\u6bd5\u4e1a\u8bc1+\u5b66\u4f4d\u8bc1\uff08\u5927\u56db\u5c31\u53ef\u4ee5\u8003\uff09</p> </li> <li> <p>\u8003\u8bd5\u65f6\u95f4\uff1a\u5341\u4e8c\u6708\u67d0\u4e2a\u5468\u672b\uff08\u4e2d\u4e0b\u65ec\uff09</p> </li> </ul> <ul> <li> <p>\u521d\u8bd5\uff1a</p> </li> <li> <p>\u516c\u5171\u8bfe\u8003\u8bd5\uff1a</p> <ul> <li> <p>\u653f\u6cbb\uff1a\u9a6c\u514b\u601d\u4e3b\u4e49\u57fa\u672c\u539f\u7406\u3001\u6bdb\u6cfd\u4e1c\u601d\u60f3\u548c\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u7406\u8bba\u4f53\u7cfb\u6982\u8bba\u3001\u4e60\u8fd1\u5e73\u65b0\u65f6\u4ee3\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u601d\u60f3\u3001\u4e2d\u56fd\u8fd1\u4ee3\u53f2\u7eb2\u8981\u3001\u601d\u60f3\u9053\u5fb7\u4fee\u517b\u4e0e\u6cd5\u5f8b\u57fa\u7840\u3001\u65f6\u653f \u7b49</p> </li> <li> <p>\u82f1\u8bed\uff1a\u5206\u4e3a \u82f1\u8bed\u4e00 \u548c \u82f1\u8bed\u4e8c \uff0c\u82f1\u8bed\u4e00\u96be\u5ea6\u8f83\u9ad8\uff08\u9898\u578b\uff1a\u5b8c\u5f62\u3001\u9605\u8bfb\u3001\u7ffb\u8bd1\u3001\u5199\u4f5c\uff09</p> </li> <li> <p>\u6570\u5b66\uff1a\u5206\u4e3a \u6570\u5b66\u4e00\u3001\u6570\u5b66\u4e8c\u3001\u6570\u5b66\u4e09\uff0c\u96be\u5ea6 \u4e00&gt;\u4e8c&gt;\u4e09\uff0c\u8003\u6838\u8303\u56f4\u76f8\u4f3c\uff08\u6570\u5b66\u4e8c\u4e0d\u8003\u6982\u7387\u7edf\u8ba1\uff09</p> </li> </ul> </li> <li> <p>\u4e13\u4e1a\u8bfe\u8003\u8bd5\uff1a</p> <ul> <li>\u7edf\u8003\uff1a</li> </ul> <p>\u8ba1\u7b97\u673a\u5b66\u79d1\u4e13\u4e1a\u57fa\u7840\u7efc\u5408408</p> <ul> <li>\u81ea\u547d\u9898\uff1a</li> </ul> <p>\u540c\u4e00\u4e2a\u4ee3\u7801\u8003\u8bd5\u5185\u5bb9\u4e5f\u4e0d\u4e00\u6837\uff0c\u6ce8\u610f\u590d\u4e60\u62a5\u8003\u5b66\u6821\u7ed9\u7684\u8003\u8bd5\u8303\u56f4</p> </li> <li> <p>\u590d\u8bd5\uff1a</p> </li> <li> <p>\u7b14\u8bd5\uff1a\u8003\u5bdf\u4e13\u4e1a\u77e5\u8bc6</p> </li> <li> <p>\u9762\u8bd5\uff1a</p> <ul> <li> <p>\u4e3b\u8981\u8003\u5bdf\u7efc\u5408\u7d20\u8d28\u3001\u4e13\u4e1a\u7d20\u8d28</p> </li> <li> <p>\u5927\u81f4\u5305\u62ec \u81ea\u6211\u4ecb\u7ecd\u3001\u672c\u79d1\u9636\u6bb5\u7ecf\u5386\uff08\u79d1\u7814\u3001\u8bba\u6587\u3001\u9879\u76ee\u3001\u7ade\u8d5b\u7b49\uff09\u3001\u82f1\u8bed\u542c\u529b\u548c\u53e3\u8bed\u3001\u4e13\u4e1a\u8bfe\u7a0b\u548c\u4e13\u4e1a\u79d1\u7814\u77e5\u8bc6\u95ee\u7b54</p> </li> </ul> </li> <li> <p>\u52a0\u8bd5(\u53ef\u80fd)\uff1a\u6280\u672f\u7c7b\u4e13\u4e1a\u53ef\u80fd\u8981\u6c42\u4e0a\u673a\u64cd\u4f5c</p> </li> </ul> <ul> <li> <p>\u5206\u6570\u6784\u6210\uff1a</p> </li> <li> <p>\u521d\u8bd5\u5206\u6570\uff1a</p> <ul> <li> <p>\u653f\u6cbb\uff1a100</p> </li> <li> <p>\u82f1\u8bed\uff1a100</p> </li> <li> <p>\u6570\u5b66\uff1a150</p> </li> <li> <p>\u4e13\u4e1a\u8bfe\uff1a150</p> </li> </ul> </li> <li> <p>\u590d\u8bd5\u5206\u6570\uff1a</p> <ul> <li>\u5173\u6ce8\u62db\u751f\u7b80\u7ae0\uff0c\u590d\u5f55\u6bd4\u4e00\u822c\u4e3a1.2~1.5 : 1</li> </ul> </li> </ul> <ul> <li> <p>\u5206\u6570\u7ebf\uff1a</p> </li> <li> <p>\u56fd\u5bb6\u7ebf\uff1a</p> <ul> <li> <p>\u603b\u5206\u7ebf\u548c\u5355\u79d1\u7ebf\uff0c\u5355\u79d1\u7ebf\u53c8\u5206\u4e3a\u6ee1\u5206100\u5206\u7684\u5355\u79d1\uff08\u5982\u653f\u6cbb\u3001\u82f1\u8bed\uff09\u7ebf\u548c\u6ee1\u5206\u5927\u4e8e100\u5206\u7684\u5355\u79d1\uff08\u5982\u6570\u5b66\u3001\u4e13\u4e1a\u8bfe\uff09\u7ebf</p> </li> <li> <p>\u56fd\u5bb6\u7ebf\u5206\u4e3a A \u7c7b\u548cB\u7c7b\u7ebf\uff0cB\u7c7b\u7ebf\u901a\u5e38\u4f1a\u6bd4A\u7c7b\u7ebf\u4f4e\u4e00\u4e9b\uff08\u4e00\u822c\u662f10\u5206\uff09</p> </li> <li> <p>A\u7c7b\u7ebf\u4e3a\u4e00\u533a\uff0c\u5305\u62ec\u5317\u4eac\u3001\u5929\u6d25\u3001\u4e0a\u6d77\u3001\u6c5f\u82cf\u3001\u6d59\u6c5f\u3001\u798f\u5efa\u3001\u5c71\u4e1c\u3001\u6cb3\u5357\u3001\u6e56\u5317\u3001\u6e56\u5357\u3001\u5e7f\u4e1c\u3001\u6cb3\u5317\u3001\u5c71\u897f\u3001\u8fbd\u5b81\u3001\u5409\u6797\u3001\u9ed1\u9f99\u6c5f\u3001\u5b89\u5fbd\u3001\u6c5f\u897f\u3001\u91cd\u5e86\u3001\u56db\u5ddd\u3001\u9655\u897f\u7b4921\u7701\uff08\u5e02\uff09</p> </li> <li> <p>B\u7c7b\u7ebf\u4e3a\u4e8c\u533a\uff0c\u5305\u62ec\u5185\u8499\u53e4\u3001\u5e7f\u897f\u3001\u6d77\u5357\u3001\u8d35\u5dde\u3001\u4e91\u5357\u3001\u897f\u85cf\u3001\u7518\u8083\u3001\u9752\u6d77\u3001\u5b81\u590f\u3001\u65b0\u7586\u7b4910\u7701\uff08\u533a\uff09</p> </li> </ul> </li> <li> <p>\u9662\u6821\u4e13\u4e1a\u7ebf\uff1a</p> <p>\u62db\u751f\u5355\u4f4d\u5728\u56fd\u5bb6\u7ebf\u7684\u57fa\u7840\u4e0a\uff0c\u6839\u636e\u672c\u6821\u6709\u5173\u4e13\u4e1a\u751f\u6e90\u4f59\u7f3a\u786e\u5b9a\u7684\u590d\u8bd5\u8d44\u683c\u7ebf\u3002</p> <p>\u901a\u4fd7\u6765\u8bf4\uff0c\u5c31\u662f\u5b66\u6821\u6839\u636e\u81ea\u5df1\u7684\u62db\u751f\u8ba1\u5212\u548c\u62a5\u8003\u672c\u6821\u8003\u751f\u7684\u6210\u7ee9\u60c5\u51b5\u5236\u5b9a\u7684\u5206\u6570\u7ebf\u3002</p> </li> <li> <p>\u4f8b\u5b50\uff1a</p> <ul> <li>\u897f\u5357\u5927\u5b66\u9662\u6821\u4e13\u4e1a\u7ebf\uff1a</li> </ul> <p></p> <ul> <li>\u56fd\u5bb6\u7ebf\uff1a</li> </ul> <p>2025\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u8003\u8bd5\u8003\u751f\u8fdb\u5165\u590d\u8bd5\u7684\u521d\u8bd5\u6210\u7ee9\u57fa\u672c\u8981\u6c42</p> </li> <li> <p>\u81ea\u5212\u7ebf\uff1a985\u9662\u6821\uff0c\u5206\u6570\u7ebf\u4e00\u822c\u9ad8\u4e8e\u56fd\u5bb6\u7ebf\uff0c\u65e9\u4e8e\u56fd\u5bb6\u7ebf\u516c\u5e03</p> </li> </ul>"},{"location":"blog/","title":"Blog","text":""}]}